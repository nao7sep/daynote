<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DayNote.Desktop.ViewModels"
        xmlns:ctl="using:DayNote.Desktop.Controls"
        x:Class="DayNote.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DayNote"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <!-- Accelerators are driven from ShortcutCatalog in code-behind so the command key resolves to
         Cmd on macOS and Ctrl on Windows (a static XAML gesture cannot do that). -->

    <Window.Styles>
        <Style Selector="TextBlock.over">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.pane">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <!-- Give list rows breathing room so the title and subtitle lines do not touch. -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Styles>

    <Panel>
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding NotebookTitle}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource Utility}" CornerRadius="4" Padding="6,2"
                            VerticalAlignment="Center" IsVisible="{Binding IsReadOnly}">
                        <TextBlock Text="read-only" FontSize="11"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="8">
                    <!-- Settings / Shortcuts / About live in a hamburger menu, matching the fleet. -->
                    <Button Classes="utility" Padding="14,6" ToolTip.Tip="Menu" AutomationProperties.Name="Menu">
                        <!-- Hamburger as a vector (three equal strokes); the glyph ☰ renders unevenly across fonts. -->
                        <Path Width="18" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                              Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" StrokeLineCap="Round"
                              UseLayoutRounding="True" Data="M0,1 H18 M0,7 H18 M0,13 H18"/>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Settings" Click="Settings_Click"/>
                                <MenuItem Header="Shortcuts" Click="Shortcuts_Click"/>
                                <MenuItem Header="About" Click="About_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <!-- App-wide state only (per-entry info lives in the editor header). The transient
                 "Saved" message clears itself shortly after a save, like quickdeck. -->
            <TextBlock Text="{Binding SaveStateText}" Margin="12,5" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </Border>

        <!-- Four panes -->
        <Grid x:Name="PaneGrid" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="170"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="170"/>
            </Grid.ColumnDefinitions>

            <!-- Recent notebooks -->
            <Border x:Name="RecentPane" Grid.Column="0" Classes="pane">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="paneHeader">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Notebooks" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <Button Content="New" Classes="accent" Command="{Binding NewNotebookCommand}"/>
                                <Button Content="Open" Classes="utility" Command="{Binding OpenNotebookCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DockPanel Margin="10">
                        <TextBox DockPanel.Dock="Top" PlaceholderText="Filter…" Text="{Binding RecentFilter}" Margin="0,0,0,8"/>
                        <!-- Selecting a notebook opens it (single click or arrow key); no double-click needed. -->
                        <ListBox x:Name="RecentList" ItemsSource="{Binding RecentNotebooks}"
                                 SelectedItem="{Binding SelectedRecent}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:RecentNotebookItemViewModel">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Directory}" FontSize="11" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <!-- Close affordance on the open notebook's row (revealed on hover/selection),
                                             replacing the old separate "Close notebook" button. -->
                                        <Button Grid.Column="1" Classes="rowAction" Click="CloseNotebookRow_Click"
                                                IsVisible="{Binding IsCurrent}" ToolTip.Tip="Close notebook">
                                            <Path Width="11" Height="11" Stroke="{Binding $parent[Button].Foreground}"
                                                  StrokeThickness="1.6" StrokeLineCap="Round" Data="M0,0 L11,11 M11,0 L0,11"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Notes -->
            <Border x:Name="NotesPane" Grid.Column="2" Classes="pane">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="paneHeader">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Notes" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1" Content="New" Classes="accent"
                                    Command="{Binding NewNoteCommand}" IsEnabled="{Binding HasNotebook}"/>
                        </Grid>
                    </Border>
                    <DockPanel Margin="10">
                        <TextBox x:Name="NotesFilterBox" DockPanel.Dock="Top" PlaceholderText="Filter…" Text="{Binding NotesFilter}" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Notes}" SelectedItem="{Binding SelectedNote}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:NoteListItemViewModel">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <!-- Lifecycle status, colored per state, so list items read differently by state. -->
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{Binding StatusBrush}"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Per-row delete, revealed on hover/selection (replaces the Delete button). -->
                                        <Button Grid.Column="1" Classes="rowAction" Click="DeleteNoteRow_Click" ToolTip.Tip="Delete note">
                                            <Path Width="11" Height="11" Stroke="{Binding $parent[Button].Foreground}"
                                                  StrokeThickness="1.6" StrokeLineCap="Round" Data="M0,0 L11,11 M11,0 L0,11"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Editor -->
            <Border Grid.Column="4" Classes="pane">
                <Panel>
                    <TextBlock Text="Select a note, or create one." HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding !Editor.HasNote}"/>
                    <DockPanel IsVisible="{Binding Editor.HasNote}">
                        <!-- Editor header: the title field and per-entry metadata, separated from the body
                             by a borderline (consistent with the other panes). The wide editor pane gives
                             the metadata room, so it no longer crowds a cramped footer. -->
                        <Border DockPanel.Dock="Top" Classes="paneHeader">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <ctl:ComposingTextBox x:Name="TitleBox"
                                                          Text="{Binding Editor.Title}" PlaceholderText="Title…"
                                                          FontSize="18" FontWeight="SemiBold" AcceptsReturn="False"
                                                          Submitted="Title_Submitted" LostFocus="Title_LostFocus"/>
                                    <!-- Lifecycle status picker: draft / checked / published / expired. -->
                                    <ComboBox Grid.Column="1" Margin="8,0,0,0" MinWidth="130" VerticalAlignment="Center"
                                              ItemsSource="{Binding Editor.StatusOptions}"
                                              SelectedItem="{Binding Editor.Status}"
                                              ToolTip.Tip="Lifecycle status"/>
                                </Grid>
                                <WrapPanel>
                                    <TextBlock Text="{Binding Editor.CreatedText}" FontSize="11" Margin="0,0,16,2" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Editor.ModifiedText}" FontSize="11" Margin="0,0,16,2" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Editor.WordsText}" FontSize="11" Margin="0,0,16,2" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Editor.CharsText}" FontSize="11" Margin="0,0,16,2" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Editor.XCountText}" FontSize="11" Margin="0,0,16,2"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Classes.over="{Binding !Editor.IsWithinXLimit}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <TextBox x:Name="BodyBox" Margin="10"
                                 Text="{Binding Editor.Body}"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 FontFamily="{Binding EditorFontFamily}" FontSize="{Binding EditorFontSize}"
                                 LineHeight="{Binding EditorLineHeight}" Padding="{Binding EditorPadding}"
                                 FontWeight="{Binding EditorFontWeight}" FontStyle="{Binding EditorFontStyle}"
                                 VerticalContentAlignment="Top"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Panel>
            </Border>

            <GridSplitter Grid.Column="5" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Attachments -->
            <Border x:Name="AttachPane" Grid.Column="6" Classes="pane">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="paneHeader">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Attachments" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1" Content="Add" Classes="utility"
                                    Command="{Binding AddAttachmentCommand}" IsEnabled="{Binding Editor.HasNote}"/>
                        </Grid>
                    </Border>
                    <Panel Margin="10">
                        <TextBlock Text="No attachments yet." HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding ShowAttachmentsEmptyHint}"/>
                        <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Attachments}" HorizontalAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AttachmentItemViewModel">
                                    <Border Margin="0,0,0,6" Padding="7" CornerRadius="6"
                                            Background="{StaticResource ListBackgroundBrush}"
                                            DoubleTapped="Attachment_DoubleTapped">
                                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="9">
                                            <Border Width="52" Height="52" CornerRadius="4" ClipToBounds="True"
                                                    Background="{StaticResource AppBackgroundBrush}">
                                                <Panel>
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                           IsVisible="{Binding HasThumbnail}"/>
                                                    <!-- Generic document with a folded corner for non-images and failed previews. -->
                                                    <Path Width="28" Height="34" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5"
                                                          Fill="Transparent"
                                                          Data="M2,1 H18 L26,9 V33 H2 Z M18,1 V9 H26"
                                                          IsVisible="{Binding ShowFilePlaceholder}"/>
                                                </Panel>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="2" Content="Remove" Classes="destructive"
                                                    FontSize="10" Padding="7,3" VerticalAlignment="Center"
                                                    Click="RemoveAttachment_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Panel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

    <!-- Toast overlay: top-right, below the toolbar; auto-dismissing cards from the Toasts collection. -->
    <ItemsControl ItemsSource="{Binding Toasts}"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,24,24,0" Width="400" ZIndex="100">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:ToastViewModel">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" BoxShadow="0 6 20 0 #50000000">
                    <Grid ColumnDefinitions="4,*">
                        <Border Background="{Binding Accent}" CornerRadius="8,0,0,8"/>
                        <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                                   Margin="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Panel>
</Window>
