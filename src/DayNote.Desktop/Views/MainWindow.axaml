<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DayNote.Desktop.ViewModels"
        xmlns:ctl="using:DayNote.Desktop.Controls"
        x:Class="DayNote.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding NotebookTitle}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewNotebookCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenNotebookCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseNotebookCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding NewNoteCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveNowCommand}"/>
        <KeyBinding Gesture="Ctrl+J" Command="{Binding CycleTextStyleCommand}"/>
        <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}"/>
        <KeyBinding Gesture="F1" Command="{Binding OpenShortcutsCommand}"/>
        <KeyBinding Gesture="Ctrl+OemQuestion" Command="{Binding OpenShortcutsCommand}"/>
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="TextBlock.over">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.pane">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <!-- Give list rows breathing room so the title and subtitle lines do not touch. -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding NotebookTitle}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource Utility}" CornerRadius="4" Padding="6,2"
                            VerticalAlignment="Center" IsVisible="{Binding IsReadOnly}">
                        <TextBlock Text="read-only" FontSize="11"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="8">
                    <Button Content="Close notebook" Classes="utility" Command="{Binding CloseNotebookCommand}" IsEnabled="{Binding HasNotebook}"/>
                    <!-- Settings / Shortcuts / About live in a hamburger menu, matching the fleet. -->
                    <Button Classes="utility" Padding="14,6" ToolTip.Tip="Menu" AutomationProperties.Name="Menu">
                        <!-- Hamburger as a vector (three equal strokes); the glyph ☰ renders unevenly across fonts. -->
                        <Path Width="18" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                              Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" StrokeLineCap="Round"
                              UseLayoutRounding="True" Data="M0,1 H18 M0,7 H18 M0,13 H18"/>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Settings" Click="Settings_Click"/>
                                <MenuItem Header="Shortcuts" Click="Shortcuts_Click"/>
                                <MenuItem Header="About" Click="About_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="12,5">
                <TextBlock Text="{Binding SaveStateText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding DataDirectory}" Margin="16,0,0,0"
                           VerticalAlignment="Center" FontSize="11" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding Editor.WordsText}" Margin="12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding Editor.CharsText}" Margin="12,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="{Binding Editor.XCountText}" Margin="12,0" VerticalAlignment="Center"
                           Classes.over="{Binding !Editor.IsWithinXLimit}"/>
            </Grid>
        </Border>

        <!-- Four panes -->
        <Grid x:Name="PaneGrid" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="170"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260" MinWidth="170"/>
            </Grid.ColumnDefinitions>

            <!-- Recent notebooks -->
            <Border x:Name="RecentPane" Grid.Column="0" Classes="pane">
                <DockPanel Margin="10">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Text="Notebooks" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Content="New" Classes="accent" Command="{Binding NewNotebookCommand}"/>
                            <Button Content="Open" Classes="utility" Command="{Binding OpenNotebookCommand}"/>
                        </StackPanel>
                    </Grid>
                    <TextBox DockPanel.Dock="Top" PlaceholderText="Filter…" Text="{Binding RecentFilter}" Margin="0,0,0,8"/>
                    <ListBox x:Name="RecentList" ItemsSource="{Binding RecentNotebooks}"
                             SelectedItem="{Binding SelectedRecent}"
                             Tapped="RecentList_Tapped" KeyDown="RecentList_KeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:RecentNotebookItemViewModel">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Directory}" FontSize="11" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Notes -->
            <Border x:Name="NotesPane" Grid.Column="2" Classes="pane">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Notes" FontWeight="Bold"/>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,8">
                        <Button Content="New" Classes="accent" Command="{Binding NewNoteCommand}" IsEnabled="{Binding HasNotebook}"/>
                        <Button Content="Delete" Classes="destructive" Command="{Binding DeleteNoteCommand}" IsEnabled="{Binding HasNotebook}"/>
                    </StackPanel>
                    <TextBox x:Name="NotesFilterBox" DockPanel.Dock="Top" PlaceholderText="Filter…" Text="{Binding NotesFilter}" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding Notes}" SelectedItem="{Binding SelectedNote}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:NoteListItemViewModel">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Editor -->
            <Border Grid.Column="4" Classes="pane">
                <Panel Margin="12">
                    <TextBlock Text="Select a note, or create one." HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding !Editor.HasNote}"/>
                    <DockPanel IsVisible="{Binding Editor.HasNote}">
                        <ctl:ComposingTextBox x:Name="TitleBox" DockPanel.Dock="Top"
                                              Text="{Binding Editor.Title}" PlaceholderText="Title"
                                              FontSize="18" FontWeight="SemiBold" AcceptsReturn="False"
                                              Submitted="Title_Submitted" LostFocus="Title_LostFocus"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="16" Margin="2,8,0,0">
                            <TextBlock Text="{Binding Editor.CreatedText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding Editor.ModifiedText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBox x:Name="BodyBox" Margin="0,8"
                                 Text="{Binding Editor.Body}"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                                 FontFamily="{Binding EditorFontFamily}" FontSize="{Binding EditorFontSize}"
                                 LineHeight="{Binding EditorLineHeight}" Padding="{Binding EditorPadding}"
                                 FontWeight="{Binding EditorFontWeight}" FontStyle="{Binding EditorFontStyle}"
                                 VerticalContentAlignment="Top"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Panel>
            </Border>

            <GridSplitter Grid.Column="5" Width="6" Background="Transparent" ResizeDirection="Columns"/>

            <!-- Attachments -->
            <Border x:Name="AttachPane" Grid.Column="6" Classes="pane">
                <DockPanel Margin="10">
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Text="Attachments" FontWeight="Bold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="Add…" Classes="utility"
                                Command="{Binding AddAttachmentCommand}" IsEnabled="{Binding Editor.HasNote}"/>
                    </Grid>
                    <Panel>
                        <TextBlock Text="No attachments yet." HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" IsVisible="{Binding ShowAttachmentsEmptyHint}"/>
                        <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Attachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AttachmentItemViewModel">
                                    <Border Width="120" Margin="4" Padding="6" CornerRadius="6"
                                            Background="{StaticResource AppBackgroundBrush}"
                                            DoubleTapped="Attachment_DoubleTapped">
                                        <StackPanel>
                                            <Image Source="{Binding Thumbnail}" Height="90" Stretch="Uniform" IsVisible="{Binding IsImage}"/>
                                            <TextBlock Text="{Binding FileName}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                            <Button Content="Remove" Classes="destructive" FontSize="10" Padding="6,2"
                                                    HorizontalAlignment="Center" Margin="0,4,0,0" Click="RemoveAttachment_Click"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Panel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
