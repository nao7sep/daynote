<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DayNote.Desktop.App"
             xmlns:local="using:DayNote.Desktop"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- Tone down FluentTheme's near-white input borders (TextBox/ComboBox/NumericUpDown)
                         to a subtle neutral. The inputs resolve their border from these brushes; flat
                         overrides replace the bright gradient edge. Focus keeps the accent indicator. -->
                    <Color x:Key="ControlStrokeColorDefault">#2C313A</Color>
                    <Color x:Key="ControlStrokeColorSecondary">#2C313A</Color>
                    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="#2C313A"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#2C313A"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3A4150"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#2C313A"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

        <Color x:Key="AppBackground">#14161A</Color>
        <Color x:Key="Surface">#1B1E24</Color>
        <Color x:Key="Border">#2C313A</Color>
        <Color x:Key="TextPrimary">#E6E9EF</Color>
        <Color x:Key="TextSecondary">#9098A6</Color>
        <Color x:Key="Accent">#3B82F6</Color>
        <Color x:Key="AccentHover">#2F6FE0</Color>
        <Color x:Key="Danger">#EF4444</Color>
        <Color x:Key="DangerHover">#DC2626</Color>
        <Color x:Key="Utility">#2A2F38</Color>
        <Color x:Key="UtilityHover">#353B45</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.utility">
            <Setter Property="Background" Value="{StaticResource Utility}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.utility:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource UtilityHover}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style Selector="Button.destructive">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.destructive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHover}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Neutral list selection/hover. FluentTheme tints these with the macOS system accent, which
             can read as yellow/orange depending on the user's system setting; force a neutral dark. -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Utility}"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Utility}"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource UtilityHover}"/>
        </Style>

        <!-- Subtle resting border on text inputs; the theme's accent focus indicator still shows on focus. -->
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>

        <!-- Flat list-item button used for recent notebooks -->
        <Style Selector="Button.listitem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.listitem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Utility}"/>
        </Style>
    </Application.Styles>
</Application>
